# ── Telegram API credentials ─────────────────────────────────────────────────
# Get these from https://my.telegram.org → "API development tools"
API_ID=your_api_id
API_HASH=your_api_hash

# The phone number linked to your Telegram account (international format)
PHONE_NUMBER=+1234567890

# ── Forwarding targets ────────────────────────────────────────────────────────
# Comma-separated list of GROUP IDs to forward messages into.
# Run the bot once to generate group_ids.txt which lists all your groups.
TARGET_GROUP_IDS=-1001234567890,-1009876543210

# ── Source channels ───────────────────────────────────────────────────────────
# Comma-separated list of channel usernames (without @) to monitor for new posts.
CHANNEL_USERNAMES=channel_username1,channel_username2

# ── Timing ───────────────────────────────────────────────────────────────────
# Random delay (in seconds) between each forwarding action.
MIN_TIME=30
MAX_TIME=60
